{
  "name": "react-effects",
  "version": "0.1.0",
  "description": "Production-ready React component library for reusable visual effects with Tailwind CSS support",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "react-component",
    "effects",
    "cursor",
    "background",
    "animation",
    "visual-effects",
    "tailwind",
    "tailwindcss",
    "typescript",
    "nextjs",
    "ssr",
    "cursor-effects",
    "background-effects",
    "ui-effects",
    "interactive",
    "particles",
    "gradient",
    "mesh",
    "hexagons"
  ],
  "author": "Your Name",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/react-effects"
  },
  "bugs": {
    "url": "https://github.com/yourusername/react-effects/issues"
  },
  "homepage": "https://github.com/yourusername/react-effects#readme",
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cursor": {
      "import": "./dist/cursor/index.mjs",
      "require": "./dist/cursor/index.js",
      "types": "./dist/cursor/index.d.ts"
    },
    "./background": {
      "import": "./dist/background/index.mjs",
      "require": "./dist/background/index.js",
      "types": "./dist/background/index.d.ts"
    }
  },
  "license": "MIT"
}
