{
  "name": "react-effects",
  "version": "0.1.0",
  "description": "Production-ready React component library for reusable visual effects",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "effects",
    "cursor",
    "background",
    "animation",
    "visual-effects"
  ],
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cursor": {
      "import": "./dist/cursor/index.mjs",
      "require": "./dist/cursor/index.js",
      "types": "./dist/cursor/index.d.ts"
    },
    "./background": {
      "import": "./dist/background/index.mjs",
      "require": "./dist/background/index.js",
      "types": "./dist/background/index.d.ts"
    }
  },
  "license": "MIT"
}
